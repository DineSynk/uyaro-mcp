{
    "name": "@uyaro/mcp",
    "version": "0.1.2",
    "description": "MCP server for the Uyaro POS platform — lets AI agents operate restaurants via Claude",
    "keywords": [
        "mcp",
        "uyaro",
        "pos",
        "restaurant",
        "ai",
        "claude"
    ],
    "homepage": "https://uyaro.in",
    "repository": {
        "type": "git",
        "url": "https://github.com/DineSynk/uyaro-mcp.git"
    },
    "license": "MIT",
    "type": "module",
    "main": "index.js",
    "bin": {
        "uyaro-mcp": "index.js"
    },
    "scripts": {
        "build": "bun build src/index.ts --outfile dist/index.js --target node --format esm --minify && node scripts/prepare-dist.mjs",
        "dev": "bun src/index.ts"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.0.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "typescript": "^5.0.0"
    },
    "engines": {
        "node": ">=20"
    }
